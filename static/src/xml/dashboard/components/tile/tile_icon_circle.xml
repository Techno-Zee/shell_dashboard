<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.TileIconCircle" owl="1">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
                <h6 class="mb-0 fw-bold" t-esc="props.block.name" />
                <div class="btn-group btn-group-sm">
                    <button t-on-click="configureBlock" class="btn btn-outline-secondary" type="button">
                        <i class="fa fa-cog" />
                    </button>
                    <button t-on-click="deleteBlock" class="btn btn-outline-danger" type="button">
                        <i class="fa fa-trash" />
                    </button>
                </div>
            </div>
            <div t-att-style="'background-color: ' + props.block.config.colors.background" class="card-body p-3 d-flex align-items-center">
                <div class="flex-grow-1">
                    <div t-att-style="'color: ' + props.block.config.colors.value" class="display-5 fw-bold mb-1">
                        <t t-esc="props.block.data.formatted_value" />
                    </div>
                    <div t-att-style="'color: ' + props.block.config.colors.text" class="small text-muted">
                        <t t-esc="props.block.name" />
                    </div>
                </div>
                <div class="bg-light rounded-circle p-3 ms-3" t-att-style="'background-color:' + props.block.config.colors.iconBg + '!important'">
                    <i t-att-class="props.block.config.icon + ' fa-2x'" t-att-style="'color: ' + props.block.config.colors.icon" />
                </div>
                <div t-on-dblclick.stop="openRecords" class="overlay" />
            </div>
        </div>
    </t>
</templates>