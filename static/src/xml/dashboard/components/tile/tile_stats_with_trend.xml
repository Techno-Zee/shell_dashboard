<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.TileStatsWithTrend" owl="1">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
                <h6 class="mb-0 fw-bold" t-esc="props.block.name" />
                <div class="btn-group btn-group-sm">
                    <button t-on-click="configureBlock" class="btn btn-outline-secondary" type="button">
                        <i class="fa fa-cog" />
                    </button>
                    <button t-on-click="deleteBlock" class="btn btn-outline-danger" type="button">
                        <i class="fa fa-trash" />
                    </button>
                </div>
            </div>
            <div t-att-style="'background-color: ' + props.block.config.colors.background" class="card-body p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="display-5 fw-bold" t-att-style="'color:' + props.block.config.colors.value">
                            <t t-esc="props.block.data.formatted_value" />
                        </div>
                        <div class="mt-2">
                            <span t-att-class="'badge ' + (props.block.data.trend_direction === 'up' ? 'bg-success' : 'bg-danger')">
                                <i t-att-class="getTrendIcon(props.block.data.trend_direction)" />
                                <t t-esc="Math.abs(props.block.data.trend).toFixed(1) + '%'" />
                            </span>
                            <span class="small text-muted ms-2">vs previous period</span>
                        </div>
                    </div>
                    <i t-att-class="props.block.config.icon + ' fa-3x'" t-att-style="'color:' + props.block.config.colors.icon" />
                </div>
                <div t-on-dblclick.stop="openRecords" class="overlay" />
            </div>
        </div>
    </t>
</templates>