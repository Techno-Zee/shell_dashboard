<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.KPIRingProgress" owl="1">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center p-2 border-bottom">
                <h6 t-esc="props.block.name" class="mb-0 fw-bold" />
                <div class="btn-group btn-group-sm">
                    <button t-on-click="configureBlock" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-cog" />
                    </button>
                    <button t-on-click="deleteBlock" class="btn btn-sm btn-outline-danger ms-1">
                        <i class="fa fa-trash" />
                    </button>
                </div>
            </div>
            <div t-att-style="'background-color: ' + props.block.config.colors.background" class="card-body px-3">
                <div class="kpi-card d-flex justify-content-between align-items-center">
                    <!-- LEFT SIDE -->
                    <div>
                        <div class="display-5 fw-bold mb-1">
                            <t t-esc="props.block.data.formatted_value" />
                        </div>
                        <span>
                            <div t-att-style="'color: ' + props.block.config.colors.text" class="kpi-label small">
                                <t t-esc="props.block.name" />
                            </div>
                            <span t-att-class="'badge ' + getTrendClass(props.block.data.trend_direction)+' text-light'">
                                <i t-att-class="getTrendIcon(props.block.data.trend_direction)" />
                                <t t-esc="Math.abs(props.block.data.trend).toFixed(1) + '%'" />
                            </span>
                        </span>
                    </div>
                    <!-- RIGHT SIDE: Ring Progress -->
                    <div>
                        <div t-att-data-progress="props.block.data.achievement" t-ref="ring" class="progress-ring">
                            <svg viewBox="0 0 120 120" preserveAspectRatio="xMidYMid meet" style="width:70px;height:70px;">
                                <circle class="progress-bg" cx="60" cy="60" r="50" stroke="#e9ecef" stroke-width="8" fill="none" />
                                <circle class="progress-bar" cx="60" cy="60" r="50" stroke="#4318ff" stroke-width="8" fill="none" stroke-dasharray="314" t-attf-stroke-dashoffset="{{ 314 - (314 * props.block.data.achievement / 100) }}" stroke-linecap="round" />
                            </svg>
                        </div>
                        <div class="kpi-percent text-center mt-1">
                            <t t-esc="Math.min(props.block.data.achievement,100).toFixed(0)" />%
                        </div>
                    </div>
                </div>
                <div t-on-dblclick.stop="openRecords" class="overlay" />
            </div>
        </div>
    </t>
</templates>