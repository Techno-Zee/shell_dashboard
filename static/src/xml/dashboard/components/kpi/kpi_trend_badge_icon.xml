<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.KPITrendBadgeIcon" owl="1">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center p-2 border-bottom">
                <h6 t-esc="props.block.name" class="mb-0 fw-bold" />
                <div class="btn-group btn-group-sm">
                    <button t-on-click="configureBlock" class="btn btn-sm btn-outline-secondary">
                        <i class="fa fa-cog" />
                    </button>
                    <button t-on-click="deleteBlock" class="btn btn-sm btn-outline-danger ms-1">
                        <i class="fa fa-trash" />
                    </button>
                </div>
            </div>
            <div t-att-style="'background-color: ' + props.block.config.colors.background" class="card-body py-3 px-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="display-5 fw-bold mb-2" t-att-style="'color:' + props.block.config.colors.value">
                            <t t-esc="props.block.data.formatted_value" />
                        </div>
                        <div t-att-style="'color:' + props.block.config.colors.text" class="small mb-2">
                            <t t-esc="props.block.name" />
                        </div>
                        <span t-att-class="'badge fs-6 py-1 px-2 ' + (props.block.data.trend_direction === 'up' ? 'bg-success' : 'bg-danger')">
                            <i t-att-class="getTrendIcon(props.block.data.trend_direction)" />
                            <t t-esc="Math.abs(props.block.data.trend).toFixed(1) + '%'" />
                            <span class="ms-1">vs last period</span>
                        </span>
                    </div>
                    <div class="rounded-circle bg-white bg-opacity-25 p-3">
                        <i t-att-class="props.block.config.icon + ' fa-3x'" t-att-style="'color:' + props.block.config.colors.icon" />
                    </div>
                </div>
                <div t-on-dblclick.stop="openRecords" class="overlay" />
            </div>
        </div>
    </t>
</templates>