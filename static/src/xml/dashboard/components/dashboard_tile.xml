<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.DashboardTile" owl="1">
        <div class="card w-100">
            <!-- Body dengan background dinamis -->
            <div  class="card-body p-3 d-flex align-items-center" style="position: relative;">
                <button t-on-click="configureBlock" class="btn btn-light btn-setting" type="button">
                    <i class="fa fa-cog" />
                </button>
                <!-- ========== VARIAN 1: TILE ICON CIRCLE ========== -->
                <t t-if="state.TileTheme == 'tile_icon_circle'">
                    <div class="flex-grow-1">
                        <div t-att-style="'color: ' + props.block.config.colors.text" class="fwt-black">
                            <t t-esc="props.block.data.formatted_value" />
                        </div>
                        <div class="small text-muted">
                            <t t-esc="props.block.name" />
                        </div>
                    </div>
                    <div class="bg-light rounded-circle p-3 ms-3" >
                        <i t-att-class="props.block.config.icon + ' fa-2x'" t-att-style="'color: ' + props.block.config.colors.icon" />
                    </div>
                </t>
                <!-- ========== VARIAN 2: TILE STATS WITH TREND ========== -->
                <t t-elif="state.TileTheme == 'tile_stats_with_trend'">
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="fwt-black" t-att-style="'color:' + props.block.config.colors.text">
                                <t t-esc="props.block.data.formatted_value" />
                            </div>
                            <i t-att-class="props.block.config.icon + ' fa-3x'" t-att-style="'color:' + props.block.config.colors.icon" />
                        </div>
                        <div class="mt-2">
                            <span t-att-class="'badge ' + getTrendClass(props.block.data.trend_direction)+' text-light'">
                                <i t-att-class="getTrendIcon(props.block.data.trend_direction)" />
                                <t t-esc="Math.abs(props.block.data.trend).toFixed(1) + '%'" />
                            </span>
                        </div>
                    </div>
                </t>
                <!-- ========== VARIAN 3: TILE COMPACT SUBVALUE ========== -->
                <t t-elif="state.TileTheme == 'tile_compact_subvalue'">
                    <div class="flex-grow-1">
                        <div class="fwt-black" t-att-style="'color:' + props.block.config.colors.text">
                            <t t-esc="props.block.data.formatted_value" />
                        </div>
                        <div class="small">
                            <span class="text-muted">Target: </span>
                            <strong t-att-style="'color:' + props.block.config.colors.text">
                                <t t-esc="props.block.data.secondary_value || '—'" />
                            </strong>
                        </div>
                    </div>
                    <div class="d-flex flex-column align-items-end">
                        <div class="bg-white rounded p-2 shadow-sm">
                            <i t-att-class="props.block.config.icon + ' fa-2x'" t-att-style="'color:' + props.block.config.colors.icon" />
                        </div>
                        <div class="mt-2 small text-muted">
                            <t t-esc="props.block.name || 'unit'" />
                        </div>
                    </div>
                </t>
                <!-- Overlay untuk double-click -->
                <div t-on-dblclick.stop="openRecords" class="overlay" />
            </div>
        </div>
    </t>
</templates>