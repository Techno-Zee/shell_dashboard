<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.Chart" owl="1">
        <div class="card w-100">
            <!-- Chart Header -->
            <div class="chart-header d-flex justify-content-between align-items-center p-2 border-bottom">
                <h6 t-esc="props.block.name" class="chart-title mb-0 fw-bold" />
                <button t-on-click="configureBlock" class="btn btn-outline-secondary">
                    <i class="fa fa-cog" />
                </button>
            </div>
            <!-- Chart Body -->
            <div class="chart-body p-3">
                <div t-ref="chartContainer" class="chart-container position-relative" style="height: 250px;">
                    <canvas t-ref="chartCanvas" />
                </div>
                <!-- Double-click overlay -->
            </div>
            <!-- Chart Footer -->
            <div class="chart-footer px-3 pb-2 border-top">
                <div t-on-click="openRecords" class="chart-overlay" />
                <div class="d-flex justify-content-between small text-muted">
                    <span>
                        Last updated:
                        <t t-esc="formatDate(props.block.last_update)" />
                    </span>
                    <span>Double-click to view records</span>
                </div>
            </div>
        </div>
    </t>
</templates>