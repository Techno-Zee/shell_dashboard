<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="shell_dashboard.Dashboard" owl="1">
        <div class="shell-dashboard-container">
            <DashboardHeader isAdmin="state.isAdmin"
                             onAddItem="onClickAddItem"
                             onExportPDF="exportAsPDF"
                             onExportPNG="exportAsPNG"
                             onExportCSV="exportAsCSV"
                             dateRangeText="getDateRangeText()"
                             showDatePicker="state.showDatePicker"
                             startDate="state.startDate"
                             endDate="state.endDate"
                             toggleDatePicker="() => toggleDatePicker()"
                             applyDateFilter="applyDateFilter"
                             resetDateFilter="resetDateFilter"
                             autoRefresh="state.autoRefresh"
                             refreshCountdown="state.refreshCountdown"
                             onToggleAutoRefresh="() => toggleAutoRefresh()"
                             onRefresh="() => refreshDashboard()"/>
            <!-- Konten dashboard -->
            <div class="dashboard-content flex-grow-1 overflow-auto p-3">
                <!-- BARIS ATAS: TILE & KPI -->
                <div t-if="groupedBlocks.topRow.length" class="row">
                    <div t-foreach="groupedBlocks.topRow" t-as="block" t-key="block.id" t-attf-class="#{getTopRowColClass()}">
                        <t t-component="resolveComponent(block.type)" block="block"/>
                    </div>
                </div>
                <!-- BARIS GRAFIK TABEL-->
                <div t-if="groupedBlocks.downRow.length" class="row">
                    <div t-foreach="groupedBlocks.downRow" t-as="block" t-key="block.id" t-attf-class="#{getDownRowColClass(block)}">
                        <t t-component="resolveComponent(block.type)" block="block"/>
                    </div>
                </div>
                <!-- Loading overlay -->
                <div t-if="state.loading" class="loading-overlay">
                    <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                </div>
            </div>
        </div>
    </t>
</templates>